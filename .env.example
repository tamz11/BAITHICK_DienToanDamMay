# Copy this file to .env and fill real credentials
DATABASE_URL="mysql://<user>:<pass>@<host>:<port>/<db>?ssl-mode=REQUIRED"
DIRECT_URL="mysql://<user>:<pass>@<host>:<port>/<db>?ssl-mode=REQUIRED"
JWT_SECRET="replace_with_32+_chars_secret"
NEXTAUTH_SECRET="replace_with_32+_chars_secret"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_CURRENCY_SYMBOL="$"
